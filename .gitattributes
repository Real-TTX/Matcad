# Normalize line endings. Files consumed inside Linux containers must stay LF.
* text=auto eol=lf

*.cs text eol=lf
*.cshtml text eol=lf
*.csproj text eol=lf
*.json text eol=lf
*.yml text eol=lf
Dockerfile text eol=lf
Caddyfile text eol=lf
*.sh text eol=lf

# PowerShell scripts run on Windows; CRLF is fine.
*.ps1 text eol=crlf
