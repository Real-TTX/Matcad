# Bootstrap configuration.
# Matcat replaces the running config at runtime via the admin API (/load),
# so this only needs to (a) expose the admin API to the docker network and
# (b) keep Caddy alive until the first push.
{
	admin 0.0.0.0:2019
}

:80 {
	respond "Matcat: Caddy is running, waiting for configuration." 200
}
