@model Matcat.Pages.IndexModel.RouteNode
@{
    var r = Model.Route;
    var scheme = "https";
    var url = $"{scheme}://{r.Host}";
}
<li>
    <div class="route-row">
        <icon name="routes" />
        <span class="host">@r.Host</span>
        @if (r.Wildcard)
        {
            <span class="badge badge-warn">Wildcard</span>
        }
        @if (!r.Enabled)
        {
            <span class="badge badge-muted">Inaktiv</span>
        }
        <span class="meta">
            @if (Model.LastAccess is DateTime la)
            {
                <span title="@la.ToString("u")"><icon name="clock" /> @la.ToLocalTime().ToString("dd.MM. HH:mm")</span>
                <span>@Model.LastIp</span>
            }
            else
            {
                <span class="text-muted">noch kein Zugriff</span>
            }
            @if (!r.Wildcard)
            {
                <a class="btn btn-sm btn-ghost" href="@url" target="_blank" rel="noopener" title="Öffnen"><icon name="open" /></a>
            }
            <a class="btn btn-sm btn-ghost" asp-page="/Routes/Edit" asp-route-id="@r.Id" title="Bearbeiten"><icon name="edit" /></a>
        </span>
    </div>
    @if (Model.Children.Count > 0)
    {
        <ul>
            @foreach (var child in Model.Children)
            {
                <partial name="_RouteNode" model="child" />
            }
        </ul>
    }
</li>
