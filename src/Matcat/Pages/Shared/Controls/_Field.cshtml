@model Matcat.Controls.FieldModel

@if (Model.Type == "checkbox")
{
    <div class="form-group">
        <label>
            <input type="checkbox" name="@Model.Name" value="true" checked="@Model.Checked" />
            @Model.Label
        </label>
        @if (Model.Hint != null)
        {
            <div class="hint">@Model.Hint</div>
        }
    </div>
}
else
{
    <div class="form-group">
        <label for="@Model.Name">@Model.Label</label>
        @if (Model.Type == "select")
        {
            <select id="@Model.Name" name="@Model.Name">
                @foreach (var (value, text) in Model.Options)
                {
                    if (Model.Value == value)
                    {
                        <option value="@value" selected>@text</option>
                    }
                    else
                    {
                        <option value="@value">@text</option>
                    }
                }
            </select>
        }
        else if (Model.Type == "textarea")
        {
            <textarea id="@Model.Name" name="@Model.Name" rows="4"
                      placeholder="@Model.Placeholder">@Model.Value</textarea>
        }
        else
        {
            <input id="@Model.Name" name="@Model.Name" type="@Model.Type" value="@Model.Value"
                   placeholder="@Model.Placeholder"
                   required="@(Model.Required ? "required" : null)"
                   autofocus="@(Model.Autofocus ? "autofocus" : null)" />
        }
        @if (Model.Hint != null)
        {
            <div class="hint">@Model.Hint</div>
        }
    </div>
}
