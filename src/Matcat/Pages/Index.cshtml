@page
@model Matcat.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="stat-grid">
    <div class="stat">
        <div class="value">@Model.Requests24h</div>
        <div class="label">Requests (24 h)</div>
    </div>
    <div class="stat">
        <div class="value">@Model.TotalRequests</div>
        <div class="label">Requests gesamt</div>
    </div>
    <div class="stat">
        <div class="value">@Model.ClientErrors24h</div>
        <div class="label">4xx (24 h)</div>
    </div>
    <div class="stat">
        <div class="value">@Model.ServerErrors24h</div>
        <div class="label">5xx (24 h)</div>
    </div>
</div>

<div class="card">
    <h2><icon name="routes" /> Routen</h2>
    @if (Model.Groups.Count == 0)
    {
        <p class="empty">Noch keine Routen. <a asp-page="/Routes/Edit">Erste Route anlegen</a>.</p>
    }
    else
    {
        <ul class="tree">
            @foreach (var group in Model.Groups)
            {
                <li class="domain-group">
                    <div class="domain-head"><icon name="network" /> @group.BaseDomain</div>
                    <ul>
                        @foreach (var row in group.Routes)
                        {
                            var r = row.Route;
                            <li>
                                <div class="route-row @(r.Enabled ? "" : "route-off")">
                                    <span class="rlabel">@row.Label</span>
                                    <span class="host">@r.Host</span>
                                    @if (r.Wildcard)
                                    {
                                        <span class="badge badge-warn">Wildcard</span>
                                    }
                                    @if (!r.Enabled)
                                    {
                                        <span class="badge badge-muted">Inaktiv</span>
                                    }
                                    <span class="rtarget text-muted">
                                        @if (!string.IsNullOrEmpty(r.Upstream))
                                        {
                                            @r.Upstream
                                        }
                                        else if (!string.IsNullOrEmpty(r.FallbackUrl))
                                        {
                                            <text>↪ @r.FallbackUrl</text>
                                        }
                                        else
                                        {
                                            <text>—</text>
                                        }
                                    </span>
                                    <span class="meta">
                                        @if (row.LastAccess is DateTime la)
                                        {
                                            <span title="@la.ToString("u")"><icon name="clock" /> @la.ToLocalTime().ToString("dd.MM. HH:mm")</span>
                                            <span>@row.LastIp</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">kein Zugriff</span>
                                        }
                                        @if (!r.Wildcard)
                                        {
                                            <a class="btn btn-sm btn-ghost" href="https://@r.Host" target="_blank" rel="noopener" title="Öffnen"><icon name="open" /></a>
                                        }
                                        <a class="btn btn-sm btn-ghost" asp-page="/Routes/Edit" asp-route-id="@r.Id" title="Bearbeiten"><icon name="edit" /></a>
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                </li>
            }
        </ul>
    }
</div>

<div class="card">
    <h2><icon name="clock" /> Letzte Zugriffe (Echtzeit)</h2>
    <div class="log-stream" id="log-stream"></div>
</div>

@section Scripts {
    <script>
        (function () {
            const stream = document.getElementById('log-stream');
            const fmt = n => (n < 10 ? '0' : '') + n;
            function addLine(e) {
                const d = new Date(e.timestamp);
                const t = fmt(d.getHours()) + ':' + fmt(d.getMinutes()) + ':' + fmt(d.getSeconds());
                const cls = 'st-' + Math.floor(e.status / 100);
                const row = document.createElement('div');
                row.className = 'log-line';
                row.innerHTML =
                    '<span class="text-muted">' + t + '</span>' +
                    '<span class="' + cls + '">' + e.status + '</span>' +
                    '<span>' + e.method + '</span>' +
                    '<span>' + escapeHtml(e.host) + escapeHtml(e.path) + '</span>' +
                    '<span class="text-muted">' + escapeHtml(e.remoteIp) + '</span>' +
                    '<span class="text-muted">' + Math.round(e.durationMs) + ' ms</span>';
                stream.insertBefore(row, stream.firstChild);
                while (stream.childElementCount > 200) stream.removeChild(stream.lastChild);
            }
            function escapeHtml(s) {
                return (s || '').replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
            }
            const es = new EventSource('/logs/stream');
            es.onmessage = ev => { try { addLine(JSON.parse(ev.data)); } catch (e) { } };
        })();
    </script>
}
