@page
@model Matcat.Pages.Settings.UserModel
@{
    ViewData["Title"] = Model.IsNew ? "Benutzer anlegen" : "Benutzer bearbeiten";
}
<div class="card">
    @if (Model.Error != null)
    {
        <div class="alert alert-error">@Model.Error</div>
    }
    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label asp-for="Username">Benutzername</label>
            <input asp-for="Username" autofocus autocomplete="off" />
        </div>
        <div class="form-group">
            <label asp-for="Password">Passwort</label>
            <input asp-for="Password" type="password" autocomplete="new-password"
                   placeholder="@(Model.IsNew ? "" : "leer lassen = unverändert")" />
        </div>
        <div class="form-group" style="max-width:220px">
            <label asp-for="Role">Rolle</label>
            <select asp-for="Role">
                <option value="User">User</option>
                <option value="Admin">Admin</option>
            </select>
        </div>

        <div class="btn-row">
            <button type="submit" class="btn btn-primary"><icon name="save" /> Speichern</button>
            <a class="btn" asp-page="Index"><icon name="back" /> Zurück</a>
            @if (!Model.IsNew)
            {
                <span class="spacer"></span>
                <button type="submit" class="btn btn-danger" asp-page-handler="Delete"
                        formnovalidate data-confirm="Benutzer wirklich löschen?">
                    <icon name="delete" /> Löschen
                </button>
            }
        </div>
    </form>
</div>
