@page
@model Matcat.Pages.Routes.IndexModel
@{
    ViewData["Title"] = "Routes";
}
<div class="card">
    <form method="get" class="toolbar">
        <div class="search">
            <icon name="search" />
            <input type="search" name="Q" value="@Model.Q" placeholder="Route suchen…" />
        </div>
        <select name="Status" onchange="this.form.submit()">
            <option value="" selected="@(string.IsNullOrEmpty(Model.Status))">Alle</option>
            <option value="enabled" selected="@(Model.Status == "enabled")">Aktiv</option>
            <option value="disabled" selected="@(Model.Status == "disabled")">Inaktiv</option>
        </select>
        <button type="submit" class="btn"><icon name="search" /> Suchen</button>
    </form>

    <div class="table-wrap">
        <table class="route-table">
            <thead>
                <tr>
                    <th>Host</th>
                    <th>Ziel</th>
                    <th>Auth</th>
                    <th>Status</th>
                    <th class="c-actions"></th>
                </tr>
            </thead>
            @if (Model.Groups.Count == 0)
            {
                <tbody><tr><td colspan="5" class="empty">Keine Routen gefunden.</td></tr></tbody>
            }
            @foreach (var group in Model.Groups)
            {
                <tbody class="group">
                    <tr class="parent">
                        <td colspan="5">
                            <span class="grp-name"><icon name="network" /> @group.BaseDomain</span>
                            <span class="grp-count">· @group.Routes.Count</span>
                        </td>
                    </tr>
                    @foreach (var r in group.Routes)
                    {
                        var label = Model.SubLabel(r.Host);
                        var apex = label == "@";
                        var authName = Model.AuthName(r);
                        <tr class="child @(r.Enabled ? "" : "route-off")">
                            <td class="c-name">
                                <span class="branch">↳</span>
                                @if (apex)
                                {
                                    <span class="apex">(root)</span>
                                }
                                else
                                {
                                    <span class="sub">@label</span><span class="sub-domain">.@group.BaseDomain</span>
                                }
                                @if (r.Wildcard)
                                {
                                    <span class="badge badge-warn">Wildcard</span>
                                }
                                @if (r.IsDerived)
                                {
                                    <span class="badge badge-info" title="Aus Docker-Container @r.SourceDetail">Docker</span>
                                }
                            </td>
                            <td class="rtarget">
                                @if (!string.IsNullOrEmpty(r.Upstream))
                                {
                                    @r.Upstream
                                }
                                else if (!string.IsNullOrEmpty(r.FallbackUrl))
                                {
                                    <text>↪ @r.FallbackUrl</text>
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>
                            <td>
                                @if (authName != null)
                                {
                                    <span class="badge badge-info">@authName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (r.Enabled)
                                {
                                    <span><span class="dot dot-ok"></span> Aktiv</span>
                                }
                                else
                                {
                                    <span><span class="dot dot-off"></span> Inaktiv</span>
                                }
                            </td>
                            <td class="c-actions">
                                @if (!r.IsDerived)
                                {
                                    <a class="btn btn-sm btn-ghost" asp-page="Edit" asp-route-id="@r.Id" title="Bearbeiten"><icon name="edit" /></a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            }
        </table>
    </div>

    <div class="list-actions">
        <a class="btn btn-primary" asp-page="Edit"><icon name="add" /> Neue Route</a>
    </div>
</div>
