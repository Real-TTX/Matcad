@page
@model Matcat.Pages.Routes.EditModel
@{
    ViewData["Title"] = Model.IsNew ? "Route anlegen" : "Route bearbeiten";

    string Sel(long? current, string value) =>
        (current?.ToString() ?? "") == value ? "selected" : "";
}
<div class="card">
    @if (Model.Error != null)
    {
        <div class="alert alert-error">@Model.Error</div>
    }
    <form method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label>Typ</label>
            <div class="segmented">
                <label class="seg-option">
                    <input type="radio" asp-for="RouteType" value="single" onchange="matcatRouteType('single')" />
                    <span><icon name="routes" /> Einzeldomain</span>
                </label>
                <label class="seg-option">
                    <input type="radio" asp-for="RouteType" value="wildcard" onchange="matcatRouteType('wildcard')" />
                    <span><icon name="network" /> Wildcard</span>
                </label>
            </div>
            <div class="hint" id="type-hint"></div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Host">Host</label>
                <input asp-for="Host" id="host-input" autofocus />
                <div class="hint" id="host-hint"></div>
            </div>
            <div class="form-group">
                <label asp-for="Name">Name</label>
                <input asp-for="Name" placeholder="optional – sonst wird der Host verwendet" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Upstream">Upstream (Reverse-Proxy-Ziel)</label>
                <input asp-for="Upstream" placeholder="http://backend:8080 oder whoami:80" />
            </div>
            <div class="form-group">
                <label asp-for="FallbackUrl">Fallback-URL</label>
                <input asp-for="FallbackUrl" placeholder="https://... (Redirect, wenn kein Upstream)" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="AuthenticationId">Authentication</label>
                <select asp-for="AuthenticationId">
                    @foreach (var (value, text) in Model.AuthOptions)
                    {
                        <option value="@value" selected="@(Sel(Model.AuthenticationId, value) == "selected")">@text</option>
                    }
                </select>
            </div>
            <div class="form-group" id="provider-block">
                <label asp-for="ProviderId">DNS-Provider <span class="text-muted">(für Wildcard-Zertifikat erforderlich)</span></label>
                <select asp-for="ProviderId">
                    @foreach (var (value, text) in Model.ProviderOptions)
                    {
                        <option value="@value" selected="@(Sel(Model.ProviderId, value) == "selected")">@text</option>
                    }
                </select>
                <div class="hint">Ein Wildcard-Zertifikat (<code>*.domain</code>) deckt alle Subdomains ab –
                    Subdomain-Routen brauchen dann keinen eigenen Provider.</div>
            </div>
        </div>

        <div class="form-group">
            <label>
                <input type="checkbox" asp-for="Enabled" /> Route aktiv
            </label>
        </div>

        <div class="btn-row">
            <button type="submit" class="btn btn-primary"><icon name="save" /> Speichern</button>
            <a class="btn" asp-page="Index"><icon name="back" /> Zurück</a>
            @if (!Model.IsNew)
            {
                <span class="spacer"></span>
                <button type="submit" class="btn btn-danger" asp-page-handler="Delete"
                        formnovalidate data-confirm="Route wirklich löschen?">
                    <icon name="delete" /> Löschen
                </button>
            }
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function matcatRouteType(type) {
            const host = document.getElementById('host-input');
            const provider = document.getElementById('provider-block');
            const hostHint = document.getElementById('host-hint');
            const typeHint = document.getElementById('type-hint');
            if (type === 'wildcard') {
                provider.style.display = '';
                host.placeholder = '*.example.com (oder example.com – wird zu *.)';
                hostHint.textContent = 'Deckt alle Subdomains ab. Erfordert einen DNS-Provider (DNS-01).';
                typeHint.textContent = 'Ein Zertifikat für die ganze Domain; einzelne Subdomains erben es.';
            } else {
                provider.style.display = 'none';
                host.placeholder = 'app.example.com';
                hostHint.textContent = 'Genau ein Host. Zertifikat via HTTP-Challenge – oder abgedeckt durch eine Wildcard-Route.';
                typeHint.textContent = 'Ein einzelner konkreter Host.';
            }
        }
        matcatRouteType(document.querySelector('input[name="RouteType"]:checked')?.value || 'single');
    </script>
}
