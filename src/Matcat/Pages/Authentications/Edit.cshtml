@page
@using Matcat.Config
@model Matcat.Pages.Authentications.EditModel
@{
    ViewData["Title"] = Model.IsNew ? "Authentication anlegen" : "Authentication bearbeiten";
}
<div class="card">
    @if (Model.Error != null)
    {
        <div class="alert alert-error">@Model.Error</div>
    }
    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label asp-for="Name">Name</label>
            <input asp-for="Name" autofocus placeholder="z. B. Interner Bereich" />
        </div>
        <div class="form-group">
            <label asp-for="Type">Typ</label>
            <select asp-for="Type" onchange="matcatAuthType(this.value)">
                <option value="BasicAuth">Basic Auth (Browser-Dialog)</option>
                <option value="Matcat">Matcat (Login-Portal mit Weiterleitung)</option>
            </select>
        </div>

        <div id="basic-block" style="@(Model.Type == AuthType.BasicAuth ? "" : "display:none")">
            <h2>Benutzer</h2>
            <p class="hint">Passwort leer lassen, um ein bestehendes Passwort beizubehalten.</p>
            <div class="table-wrap">
                <table class="data" id="basic-users">
                    <thead><tr><th>Benutzername</th><th>Passwort</th><th style="width:1%"></th></tr></thead>
                    <tbody>
                        @foreach (var u in Model.ExistingUsers)
                        {
                            <tr>
                                <td><input name="Usernames" value="@u.Username" /></td>
                                <td><input name="Passwords" type="password" placeholder="•••••••• (unverändert)" autocomplete="new-password" /></td>
                                <td><button type="button" class="btn btn-sm btn-ghost" onclick="this.closest('tr').remove()"><icon name="delete" /></button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="list-actions">
                <button type="button" class="btn" onclick="matcatAddUser()"><icon name="add" /> Benutzer hinzufügen</button>
            </div>
        </div>

        <div id="matcat-block" style="@(Model.Type == AuthType.Matcat ? "" : "display:none")">
            <div class="alert alert-warn">
                Beim Typ <strong>Matcat</strong> werden nicht authentifizierte Zugriffe zum
                Matcat-Login-Portal umgeleitet. Nach erfolgreicher Anmeldung wird der Benutzer
                zum ursprünglichen Endpunkt zurückgeleitet (Caddy <code>forward_auth</code>).
                Portal-URL und Basis-Domain werden unter <a asp-page="/Settings/Index">Settings</a> konfiguriert.
            </div>
        </div>

        <div class="btn-row">
            <button type="submit" class="btn btn-primary"><icon name="save" /> Speichern</button>
            <a class="btn" asp-page="Index"><icon name="back" /> Zurück</a>
            @if (!Model.IsNew)
            {
                <span class="spacer"></span>
                <button type="submit" class="btn btn-danger" asp-page-handler="Delete"
                        formnovalidate data-confirm="Authentication wirklich löschen?">
                    <icon name="delete" /> Löschen
                </button>
            }
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function matcatAuthType(t) {
            document.getElementById('basic-block').style.display = t === 'BasicAuth' ? '' : 'none';
            document.getElementById('matcat-block').style.display = t === 'Matcat' ? '' : 'none';
        }
        function matcatAddUser() {
            const tbody = document.querySelector('#basic-users tbody');
            const tr = document.createElement('tr');
            tr.innerHTML =
                '<td><input name="Usernames" /></td>' +
                '<td><input name="Passwords" type="password" autocomplete="new-password" /></td>' +
                '<td><button type="button" class="btn btn-sm btn-ghost" onclick="this.closest(\'tr\').remove()">✕</button></td>';
            tbody.appendChild(tr);
        }
    </script>
}
