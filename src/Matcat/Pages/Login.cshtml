@page
@model Matcat.Pages.LoginModel
@{
    ViewData["Title"] = "Anmelden";
    Layout = "_LoginLayout";
}
<div class="login-card">
    <h1 class="login-brand"><icon name="cat" /> Matcat</h1>
    @if (Model.Error != null)
    {
        <div class="alert alert-error">@Model.Error</div>
    }
    <form method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <div class="form-group">
            <label asp-for="Username">Benutzername</label>
            <input asp-for="Username" autocomplete="username" autofocus />
        </div>
        <div class="form-group">
            <label asp-for="Password">Passwort</label>
            <input asp-for="Password" type="password" autocomplete="current-password" />
        </div>
        <button type="submit" class="btn btn-primary btn-block">
            <icon name="logout" /> Anmelden
        </button>
    </form>
</div>
