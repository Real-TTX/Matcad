@model Matcad.Controls.DataTable
@{
    var hasEdit = Model.Rows.Any(r => r.EditUrl != null);
    var colCount = Model.Columns.Count + (hasEdit ? 1 : 0);
}

<div class="data-table" id="@Model.Id">
    <form method="get" class="toolbar">
        <div class="search">
            <icon name="search" />
            <input type="search" name="@Model.SearchParam" value="@Model.SearchValue"
                   placeholder="@Model.SearchPlaceholder" />
        </div>
        @foreach (var f in Model.Filters)
        {
            <select name="@f.Param" title="@f.Label" onchange="this.form.submit()">
                @foreach (var (value, text) in f.Options)
                {
                    if (f.Selected == value)
                    {
                        <option value="@value" selected>@text</option>
                    }
                    else
                    {
                        <option value="@value">@text</option>
                    }
                }
            </select>
        }
        @* Preserve sort while searching. *@
        @if (!string.IsNullOrEmpty(Model.Sort))
        {
            <input type="hidden" name="@Model.SortParam" value="@Model.Sort" />
            <input type="hidden" name="@Model.DirParam" value="@Model.Dir" />
        }
        @foreach (var kv in Model.ExtraQuery)
        {
            <input type="hidden" name="@kv.Key" value="@kv.Value" />
        }
        <button type="submit" class="btn"><icon name="search" /> Search</button>
    </form>

    <div class="table-wrap">
        <table class="data">
            <thead>
                <tr>
                    @foreach (var col in Model.Columns)
                    {
                        <th>
                            @if (!string.IsNullOrEmpty(col.SortKey))
                            {
                                <a href="@Model.SortLink(col.SortKey)">@col.Header @Model.SortIndicator(col.SortKey)</a>
                            }
                            else
                            {
                                @col.Header
                            }
                        </th>
                    }
                    @if (hasEdit)
                    {
                        <th style="width:1%"></th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr><td colspan="@colCount" class="empty">@Model.EmptyText</td></tr>
                }
                else
                {
                    foreach (var row in Model.Rows)
                    {
                        <tr>
                            @foreach (var cell in row.Cells)
                            {
                                <td>@cell</td>
                            }
                            @if (hasEdit)
                            {
                                <td>
                                    @if (row.EditUrl != null)
                                    {
                                        <a class="btn btn-sm btn-ghost" href="@row.EditUrl" title="Bearbeiten"><icon name="edit" /></a>
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="pagination">
            @if (Model.Page > 1)
            {
                <a href="@Model.Link((Model.PageParam, (Model.Page - 1).ToString()))">‹</a>
            }
            else
            {
                <span class="disabled">‹</span>
            }
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                if (p == Model.Page)
                {
                    <span class="current">@p</span>
                }
                else
                {
                    <a href="@Model.Link((Model.PageParam, p.ToString()))">@p</a>
                }
            }
            @if (Model.Page < Model.TotalPages)
            {
                <a href="@Model.Link((Model.PageParam, (Model.Page + 1).ToString()))">›</a>
            }
            else
            {
                <span class="disabled">›</span>
            }
        </nav>
    }
</div>
