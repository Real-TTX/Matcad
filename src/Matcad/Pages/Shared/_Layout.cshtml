@using System.Reflection
@{
    string CurrentPage(string page) =>
        (ViewContext.RouteData.Values["page"]?.ToString() ?? "").StartsWith(page, StringComparison.OrdinalIgnoreCase)
            ? "active" : "";
    var version = Assembly.GetExecutingAssembly()
        .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "local";
    var userName = User.Identity?.Name ?? "";
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Matcad</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <div class="layout">
        <aside class="sidebar">
            <div class="sidebar-brand"><partial name="_Logo" /> <span>Matcad</span></div>
            <nav class="nav">
                <a class="nav-item @CurrentPage("/Index")" asp-page="/Index"><icon name="dashboard" /> <span>Dashboard</span></a>
                <a class="nav-item @CurrentPage("/Routes")" asp-page="/Routes/Index"><icon name="routes" /> <span>Routes</span></a>
                <a class="nav-item @CurrentPage("/Authentications")" asp-page="/Authentications/Index"><icon name="auth" /> <span>Authentications</span></a>
                <a class="nav-item @CurrentPage("/Providers")" asp-page="/Providers/Index"><icon name="provider" /> <span>Providers</span></a>
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-item @CurrentPage("/Settings")" asp-page="/Settings/Index"><icon name="settings" /> <span>Settings</span></a>
                }
            </nav>
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <span class="user-badge"><icon name="auth" /> <span>@userName</span></span>
                    <a class="btn btn-ghost btn-sm" asp-page="/Logout" title="Abmelden"><icon name="logout" /> Abmelden</a>
                </div>
                <div class="sidebar-version">v@(version)</div>
            </div>
        </aside>

        <div class="main">
            <header class="topbar">
                <label for="nav-toggle" class="nav-burger" aria-label="Menü"><icon name="menu" /></label>
                <div class="topbar-title">@ViewData["Title"]</div>
            </header>
            <main class="content">
                @if (TempData["Flash"] is string flash)
                {
                    <div class="alert alert-success">@flash</div>
                }
                @if (TempData["FlashError"] is string flashError)
                {
                    <div class="alert alert-error">@flashError</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/js/matcad.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
