@page
@model Matcad.Pages.Routes.EditModel
@{
    ViewData["Title"] = Model.IsNew ? "Create route" : "Edit route";

    string Sel(long? current, string value) =>
        (current?.ToString() ?? "") == value ? "selected" : "";
}
<div class="card">
    @if (Model.Error != null)
    {
        <div class="alert alert-error">@Model.Error</div>
    }
    <form method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label>Type</label>
            <div class="segmented">
                <label class="seg-option">
                    <input type="radio" asp-for="RouteType" value="single" onchange="matcadRouteType('single')" />
                    <span><icon name="routes" /> Single domain</span>
                </label>
                <label class="seg-option">
                    <input type="radio" asp-for="RouteType" value="wildcard" onchange="matcadRouteType('wildcard')" />
                    <span><icon name="network" /> Wildcard</span>
                </label>
            </div>
            <div class="hint" id="type-hint"></div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Host">Host</label>
                <input asp-for="Host" id="host-input" autofocus />
                <div class="hint" id="host-hint"></div>
            </div>
            <div class="form-group">
                <label asp-for="Name">Name</label>
                <input asp-for="Name" placeholder="optional – otherwise the host is used" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Upstream">Upstream (reverse-proxy target)</label>
                <input asp-for="Upstream" placeholder="http://backend:8080 or whoami:80" />
            </div>
            <div class="form-group">
                <label asp-for="FallbackUrl">Fallback URL</label>
                <input asp-for="FallbackUrl" placeholder="https://... (redirect when no upstream)" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="AuthenticationId">Authentication</label>
                <select asp-for="AuthenticationId">
                    @foreach (var (value, text) in Model.AuthOptions)
                    {
                        <option value="@value" selected="@(Sel(Model.AuthenticationId, value) == "selected")">@text</option>
                    }
                </select>
            </div>
            <div class="form-group" id="provider-block">
                <label asp-for="ProviderId">DNS provider <span class="text-muted">(required for the wildcard certificate)</span></label>
                <select asp-for="ProviderId">
                    @foreach (var (value, text) in Model.ProviderOptions)
                    {
                        <option value="@value" selected="@(Sel(Model.ProviderId, value) == "selected")">@text</option>
                    }
                </select>
                <div class="hint">A wildcard certificate (<code>*.domain</code>) covers all subdomains –
                    subdomain routes then don't need their own provider.</div>
            </div>
        </div>

        <div class="form-group">
            <label>
                <input type="checkbox" asp-for="Enabled" /> Route active
            </label>
        </div>

        <div class="btn-row">
            <button type="submit" class="btn btn-primary"><icon name="save" /> Save</button>
            <a class="btn" asp-page="Index"><icon name="back" /> Back</a>
            @if (!Model.IsNew)
            {
                <span class="spacer"></span>
                <button type="submit" class="btn btn-danger" asp-page-handler="Delete"
                        formnovalidate data-confirm="Delete this route?">
                    <icon name="delete" /> Delete
                </button>
            }
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function matcadRouteType(type) {
            const host = document.getElementById('host-input');
            const provider = document.getElementById('provider-block');
            const hostHint = document.getElementById('host-hint');
            const typeHint = document.getElementById('type-hint');
            if (type === 'wildcard') {
                provider.style.display = '';
                host.placeholder = '*.example.com (or example.com – becomes *.)';
                hostHint.textContent = 'Covers all subdomains. Requires a DNS provider (DNS-01).';
                typeHint.textContent = 'One certificate for the whole domain; individual subdomains inherit it.';
            } else {
                provider.style.display = 'none';
                host.placeholder = 'app.example.com';
                hostHint.textContent = 'Exactly one host. Certificate via HTTP challenge – or covered by a wildcard route.';
                typeHint.textContent = 'A single concrete host.';
            }
        }
        matcadRouteType(document.querySelector('input[name="RouteType"]:checked')?.value || 'single');
    </script>
}
