@page
@model Matcad.Pages.Routes.IndexModel
@{
    ViewData["Title"] = "Routes";
}
<div class="card">
    <form method="get" class="toolbar">
        <div class="search">
            <icon name="search" />
            <input type="search" name="Q" value="@Model.Q" placeholder="Search routes…" />
        </div>
        <select name="Status" onchange="this.form.submit()">
            <option value="" selected="@(string.IsNullOrEmpty(Model.Status))">All</option>
            <option value="enabled" selected="@(Model.Status == "enabled")">Active</option>
            <option value="disabled" selected="@(Model.Status == "disabled")">Inactive</option>
        </select>
        <button type="submit" class="btn"><icon name="search" /> Search</button>
    </form>

    <div class="table-wrap">
        <table class="route-table">
            <thead>
                <tr>
                    <th>Host</th>
                    <th>Target</th>
                    <th>Certificate</th>
                    <th>Auth</th>
                    <th>Status</th>
                    <th class="c-actions"></th>
                </tr>
            </thead>
            @if (Model.Groups.Count == 0)
            {
                <tbody><tr><td colspan="6" class="empty">No routes found.</td></tr></tbody>
            }
            @foreach (var group in Model.Groups)
            {
                <tbody class="group">
                    <tr class="parent">
                        <td colspan="6">
                            <span class="grp-name"><icon name="network" /> @group.BaseDomain</span>
                            <span class="grp-count">· @group.Routes.Count</span>
                        </td>
                    </tr>
                    @foreach (var r in group.Routes)
                    {
                        var label = Model.SubLabel(r.Host);
                        var apex = label == "@";
                        var authName = Model.AuthName(r);
                        <tr class="child @(r.Enabled ? "" : "route-off")">
                            <td class="c-name">
                                <span class="branch">↳</span>
                                @if (apex)
                                {
                                    <span class="apex">(root)</span>
                                }
                                else
                                {
                                    <span class="sub">@label</span><span class="sub-domain">.@group.BaseDomain</span>
                                }
                                @if (r.Wildcard)
                                {
                                    <span class="badge badge-warn">Wildcard</span>
                                }
                                @if (r.Source == "system")
                                {
                                    <span class="badge badge-warn" title="Matcad self-exposure">System</span>
                                }
                                else if (r.Source == "docker")
                                {
                                    <span class="badge badge-info" title="From Docker container @r.SourceDetail">Docker</span>
                                }
                            </td>
                            <td class="rtarget">
                                @if (!string.IsNullOrEmpty(r.Upstream))
                                {
                                    @r.Upstream
                                }
                                else if (!string.IsNullOrEmpty(r.FallbackUrl))
                                {
                                    <text>↪ @r.FallbackUrl</text>
                                    <span class="badge badge-muted" title="Redirect">@(r.RedirectPermanent ? "301" : "302")</span>
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>
                            <td>
                                @{
                                    var cert = Model.Cert(r);
                                }
                                @switch (cert.Kind)
                                {
                                    case Matcad.Config.CertificatePlanner.CertKind.Wildcard:
                                        <span class="badge badge-success" title="Wildcard certificate">🛡 @cert.Subject</span>
                                        break;
                                    case Matcad.Config.CertificatePlanner.CertKind.Covered:
                                        <span class="badge badge-muted" title="Covered by wildcard certificate">🛡 @cert.Subject</span>
                                        break;
                                    case Matcad.Config.CertificatePlanner.CertKind.Internal:
                                        <span class="badge badge-muted" title="Caddy internal CA (localhost/IP)">internal</span>
                                        break;
                                    default:
                                        <span class="badge badge-warn" title="Would request its own individual certificate">⚠ Individual</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (authName != null)
                                {
                                    <span class="badge badge-info">@authName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (r.Enabled)
                                {
                                    <span><span class="dot dot-ok"></span> Active</span>
                                }
                                else
                                {
                                    <span><span class="dot dot-off"></span> Inactive</span>
                                }
                            </td>
                            <td class="c-actions">
                                @if (!r.IsDerived)
                                {
                                    <a class="btn btn-sm btn-ghost" asp-page="Edit" asp-route-id="@r.Id" title="Edit"><icon name="edit" /></a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            }
        </table>
    </div>

    <div class="list-actions">
        <a class="btn btn-primary" asp-page="Edit"><icon name="add" /> New route</a>
    </div>
</div>
