@page
@model Matcad.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}
<div class="card" data-tab-group>
    <div class="tabbar">
        <button class="tab active" data-tab="general"><icon name="settings" /> Einstellungen</button>
        <button class="tab" data-tab="users"><icon name="auth" /> Benutzer</button>
        <button class="tab" data-tab="docker"><icon name="provider" /> Docker</button>
        <button class="tab" data-tab="caddy"><icon name="routes" /> Caddy-Config</button>
    </div>

    <div class="tab-panel active" data-panel="general">
        <form method="post">
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="BaseDomain">Basis-Domain</label>
                    <input asp-for="BaseDomain" placeholder="example.com" />
                    <div class="hint">Für subdomain-übergreifende Matcad-Anmeldung (forward_auth-Cookie).</div>
                </div>
                <div class="form-group">
                    <label asp-for="AuthPortalUrl">Login-Portal-URL</label>
                    <input asp-for="AuthPortalUrl" placeholder="https://auth.example.com" />
                    <div class="hint">Ungeschützter Host, der auf Matcad zeigt.</div>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CaddyAdminUrl">Caddy Admin-URL</label>
                    <input asp-for="CaddyAdminUrl" placeholder="http://caddy:2019" />
                </div>
                <div class="form-group">
                    <label asp-for="AcmeEmail">ACME-E-Mail</label>
                    <input asp-for="AcmeEmail" type="email" placeholder="admin@example.com" />
                    <div class="hint">Für Let's-Encrypt-Registrierung.</div>
                </div>
            </div>
            <div class="form-group" style="max-width:220px">
                <label asp-for="LogRetentionDays">Log-Aufbewahrung (Tage)</label>
                <input asp-for="LogRetentionDays" type="number" min="1" />
            </div>

            <p class="hint">Caddy Admin-API: <strong>@Model.CaddyStatus</strong></p>

            <div class="btn-row">
                <button type="submit" class="btn btn-primary"><icon name="save" /> Speichern</button>
                <button type="submit" class="btn" asp-page-handler="Repush"><icon name="refresh" /> Config neu übertragen</button>
            </div>
        </form>
    </div>

    <div class="tab-panel" data-panel="users">
        <div class="table-wrap">
            <table class="data">
                <thead><tr><th>Benutzername</th><th>Rolle</th><th>Erstellt</th><th style="width:1%"></th></tr></thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>@u.Username</td>
                            <td>
                                @if (u.Role == Matcad.Data.UserRole.Admin)
                                {
                                    <span class="badge badge-info">Admin</span>
                                }
                                else
                                {
                                    <span class="badge badge-muted">User</span>
                                }
                            </td>
                            <td class="text-muted">@u.CreateDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td><a class="btn btn-sm btn-ghost" asp-page="User" asp-route-id="@u.Id" title="Bearbeiten"><icon name="edit" /></a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="list-actions">
            <a class="btn btn-primary" asp-page="User"><icon name="add" /> Neuer Benutzer</a>
        </div>
    </div>

    <div class="tab-panel" data-panel="docker">
        <p class="hint">
            Bindet laufende Container automatisch als Routen ein. Standardname:
            <code>&lt;containername&gt;.&lt;Basis-Domain&gt;</code>. Feinsteuerung über Labels –
            <code>matcad.enable=true</code>, <code>matcad.host</code>, <code>matcad.port</code>,
            <code>matcad.auth</code>. Docker-Routen erscheinen in der Routes-Liste mit Badge
            „Docker" und sind dort schreibgeschützt.
        </p>
        <form method="post" asp-page-handler="Docker">
            <div class="form-group">
                <label><input type="checkbox" asp-for="DockerEnabled" /> Docker-Discovery aktiv</label>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="DockerEndpoint">Docker-Endpoint</label>
                    <input asp-for="DockerEndpoint" placeholder="unix:///var/run/docker.sock" />
                    <div class="hint">Socket muss ins Matcad-Compose gemountet sein (read-only).</div>
                </div>
                <div class="form-group">
                    <label asp-for="DockerBaseDomain">Basis-Domain (Auto-Naming)</label>
                    <input asp-for="DockerBaseDomain" placeholder="leer = globale Basis-Domain" />
                </div>
            </div>
            <div class="form-group">
                <label><input type="checkbox" asp-for="DockerRequireLabel" /> Nur Container mit <code>matcad.enable=true</code> (empfohlen)</label>
            </div>
            <div class="btn-row">
                <button type="submit" class="btn btn-primary"><icon name="save" /> Speichern</button>
            </div>
        </form>

        <h2 style="margin-top:1.5rem">Erkannte Container</h2>
        @if (Model.DockerError != null)
        {
            <div class="alert alert-error">Docker nicht erreichbar: @Model.DockerError</div>
        }
        @if (Model.DockerDiscovered.Count == 0)
        {
            <p class="empty">Keine Container erfasst.</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="route-table">
                    <thead><tr><th>Container</th><th>Host</th><th>Ziel</th><th>Auth</th></tr></thead>
                    <tbody class="group">
                        @foreach (var r in Model.DockerDiscovered)
                        {
                            <tr class="child">
                                <td class="c-name">@r.SourceDetail</td>
                                <td>@r.Host</td>
                                <td class="rtarget">@r.Upstream</td>
                                <td>@(r.AuthenticationId is > 0 ? "✓" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="tab-panel" data-panel="caddy">
        <p class="hint">
            Automatisch generierte Caddy-Konfiguration (JSON), die Matcad über die
            Admin-API an Caddy überträgt. <strong>Nur-Lesen</strong> – Änderungen erfolgen
            über Routes, Providers und Authentications. Matcad nutzt bewusst die
            JSON-API, kein klassisches Caddyfile.
        </p>
        <div class="btn-row" style="margin-top:0; gap:.4rem">
            <button type="button" class="btn btn-sm btn-primary" id="cfg-btn-live" onclick="matcadShowConfig('live')">Live (Caddy)</button>
            <button type="button" class="btn btn-sm" id="cfg-btn-generated" onclick="matcadShowConfig('generated')">Generiert (Matcad)</button>
            <span class="spacer"></span>
            <button type="button" class="btn btn-sm" onclick="matcadCopyConfig(this)"><icon name="save" /> Kopieren</button>
        </div>
        <pre class="code-view" id="cfg-live-pre"><code id="cfg-live">@Model.CaddyLiveJson</code></pre>
        <pre class="code-view" id="cfg-generated-pre" style="display:none"><code id="cfg-generated">@Model.CaddyConfigJson</code></pre>
    </div>
</div>

@section Scripts {
    <script>
        let matcadCfgView = 'live';
        function matcadShowConfig(which) {
            matcadCfgView = which;
            document.getElementById('cfg-live-pre').style.display = which === 'live' ? '' : 'none';
            document.getElementById('cfg-generated-pre').style.display = which === 'generated' ? '' : 'none';
            document.getElementById('cfg-btn-live').classList.toggle('btn-primary', which === 'live');
            document.getElementById('cfg-btn-generated').classList.toggle('btn-primary', which === 'generated');
        }
        function matcadCopyConfig(btn) {
            const text = document.getElementById(matcadCfgView === 'live' ? 'cfg-live' : 'cfg-generated').textContent;
            navigator.clipboard.writeText(text).then(() => {
                const old = btn.innerHTML;
                btn.textContent = 'Kopiert ✓';
                setTimeout(() => btn.innerHTML = old, 1500);
            });
        }
    </script>
}
