@page
@using Matcad.Config
@model Matcad.Pages.SetupModel
@{
    Layout = "_SetupLayout";
    ViewData["Title"] = "Setup";
    var steps = new[] { ("account", "Account"), ("domains", "Domains & login"), ("provider", "DNS provider"), ("done", "Finish") };
    var current = Array.FindIndex(steps, s => s.Item1 == Model.Step);
    if (current < 0) current = 0;
}

<ol class="setup-steps">
    @for (var i = 0; i < steps.Length; i++)
    {
        <li class="@(i == current ? "active" : i < current ? "done" : "")">
            <span class="n">@(i + 1)</span> <span class="t">@steps[i].Item2</span>
        </li>
    }
</ol>

<div class="card">
    @if (Model.Error != null)
    {
        <div class="alert alert-error">@Model.Error</div>
    }
    @if (Model.TestResult is { } tr)
    {
        var cls = tr.Ok == true ? "alert-success" : (tr.Ok == false ? "alert-error" : "alert-warn");
        <div class="alert @cls">@tr.Message</div>
    }

    @if (Model.Step == "account")
    {
        <h2>Secure your account</h2>
        <p class="hint">Matcad ships with the default login <code>admin / admin</code>. Change it before you go on.</p>
        <form method="post" asp-page-handler="Account">
            <div class="form-group">
                <label asp-for="NewUsername">Username</label>
                <input asp-for="NewUsername" autocomplete="username" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="NewPassword">New password</label>
                    <input asp-for="NewPassword" type="password" autocomplete="new-password" autofocus />
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirm password</label>
                    <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
                </div>
            </div>
            <div class="btn-row">
                <button type="submit" class="btn btn-primary">Continue <icon name="open" /></button>
            </div>
        </form>
    }
    else if (Model.Step == "domains")
    {
        <h2>Domains &amp; login</h2>
        <form method="post" asp-page-handler="Domains">
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="BaseDomain">Base domain</label>
                    <input asp-for="BaseDomain" placeholder="example.com" autofocus />
                    <div class="hint">Parent domain shared by your sites. Enables one Matcad sign-in across subdomains.</div>
                </div>
                <div class="form-group">
                    <label asp-for="MatcadHost">Matcad host <span class="text-muted">(optional)</span></label>
                    <input asp-for="MatcadHost" placeholder="matcad.example.com" />
                    <div class="hint">Exposes this UI through Caddy under that domain.</div>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="PortalMode">Login behaviour</label>
                    <select asp-for="PortalMode">
                        <option value="inline">Inline – login on the protected site (hides Matcad)</option>
                        <option value="redirect">Redirect – send users to the Matcad host</option>
                        <option value="unauthorized">Unauthorized – plain 401, no login form</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="AcmeEmail">ACME email <span class="text-muted">(optional)</span></label>
                    <input asp-for="AcmeEmail" type="email" placeholder="empty = anonymous (like plain Caddy)" />
                    <div class="hint">Only for Let's Encrypt expiry notices. Leave empty — certificates still work.</div>
                </div>
            </div>
            <div class="form-group">
                <label><input type="checkbox" asp-for="SystemRouteEnabled" /> Expose the Matcad UI via the Matcad host (system route)</label>
            </div>
            <div class="btn-row">
                <button type="submit" class="btn btn-primary">Continue <icon name="open" /></button>
                <a class="btn" asp-page="Setup" asp-route-step="account"><icon name="back" /> Back</a>
            </div>
        </form>
    }
    else if (Model.Step == "provider")
    {
        <h2>DNS provider <span class="text-muted">(optional)</span></h2>
        <div class="alert alert-warn">
            Only needed for <strong>wildcard certificates</strong> (<code>*.domain</code>) via the DNS-01 challenge.
            For single hostnames Caddy uses HTTP validation — no provider required. You can skip this and add one later.
        </div>
        <form method="post">
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProviderName">Name</label>
                    <input asp-for="ProviderName" placeholder="e.g. Netcup" />
                </div>
                <div class="form-group">
                    <label asp-for="ProviderType">Type</label>
                    <select asp-for="ProviderType" onchange="matcadToggleCreds(this.value)">
                        @foreach (var t in ProviderTypes.All)
                        {
                            <option value="@t.Id">@t.DisplayName</option>
                        }
                        <option value="@ProviderTypes.CustomId">Custom (any compiled module)…</option>
                    </select>
                </div>
            </div>

            @foreach (var t in ProviderTypes.All)
            {
                <div class="cred-block" data-cred-type="@t.Id" style="@(t.Id == Model.ProviderType ? "" : "display:none")">
                    @foreach (var field in t.Fields)
                    {
                        Model.CredentialValues.TryGetValue($"{t.Id}:{field.Key}", out var val);
                        <div class="form-group">
                            <label for="cred_@(t.Id)_@(field.Key)">@field.Label</label>
                            <input id="cred_@(t.Id)_@(field.Key)" name="cred_@(t.Id)_@(field.Key)"
                                   type="@(field.Secret ? "password" : "text")" value="@val" autocomplete="off" />
                        </div>
                    }
                </div>
            }
            <div class="cred-block" data-cred-type="@ProviderTypes.CustomId" style="@(Model.ProviderType == ProviderTypes.CustomId ? "" : "display:none")">
                <div class="form-group">
                    <label>Caddy DNS module name</label>
                    <input name="CustomModule" placeholder="e.g. cloudflare, route53" autocomplete="off" />
                </div>
                <label>Credentials</label>
                <div class="table-wrap">
                    <table class="data" id="custom-creds">
                        <thead><tr><th>Key</th><th>Value</th><th style="width:1%"></th></tr></thead>
                        <tbody></tbody>
                    </table>
                </div>
                <div class="list-actions">
                    <button type="button" class="btn" onclick="matcadAddCred()"><icon name="add" /> Add credential</button>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group" style="max-width:220px">
                    <label asp-for="PropagationDelay">DNS propagation delay (s)</label>
                    <input asp-for="PropagationDelay" type="number" min="0" />
                    <div class="hint">Slow providers (netcup): 120.</div>
                </div>
                <div class="form-group" style="max-width:220px">
                    <label asp-for="PropagationTimeout">Propagation timeout (s)</label>
                    <input asp-for="PropagationTimeout" type="number" min="-1" />
                    <div class="hint">-1 = skip the check (recommended for netcup).</div>
                </div>
            </div>

            <div class="btn-row">
                <button type="submit" class="btn btn-primary" asp-page-handler="ProviderSave"><icon name="save" /> Save &amp; continue</button>
                <button type="submit" class="btn" asp-page-handler="ProviderTest" formnovalidate><icon name="check" /> Test credentials</button>
                <button type="submit" class="btn btn-ghost" asp-page-handler="SkipProvider" formnovalidate>Skip <icon name="open" /></button>
            </div>
        </form>
    }
    else // done
    {
        <h2>You're set up 🎉</h2>
        <p class="hint">Next, add the sites Caddy should serve — create routes by hand, or import an existing Caddyfile.</p>
        <div class="list-actions" style="margin-bottom:1rem">
            <a class="btn" asp-page="/Routes/Edit"><icon name="add" /> Add a route</a>
            <a class="btn" asp-page="/Settings/Import"><icon name="routes" /> Import a Caddyfile</a>
        </div>
        <form method="post" asp-page-handler="Finish">
            <div class="btn-row">
                <button type="submit" class="btn btn-primary"><icon name="check" /> Finish setup</button>
                <a class="btn" asp-page="Setup" asp-route-step="provider"><icon name="back" /> Back</a>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        function matcadToggleCreds(type) {
            document.querySelectorAll('.cred-block').forEach(b => {
                b.style.display = b.getAttribute('data-cred-type') === type ? '' : 'none';
            });
        }
        function matcadAddCred() {
            const tbody = document.querySelector('#custom-creds tbody');
            const tr = document.createElement('tr');
            tr.innerHTML =
                '<td><input name="CustomKeys" autocomplete="off" /></td>' +
                '<td><input name="CustomValues" autocomplete="off" /></td>' +
                '<td><button type="button" class="btn btn-sm btn-ghost" onclick="this.closest(\'tr\').remove()">✕</button></td>';
            tbody.appendChild(tr);
        }
    </script>
}
